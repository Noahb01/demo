# Public site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://shipshelter.example.com

# Sanity (https://www.sanity.io/manage) — optional; demo listings used if unset
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Mapbox (https://account.mapbox.com/) — optional; fallback link shown if unset
NEXT_PUBLIC_MAPBOX_TOKEN=

# Resend (https://resend.com) — optional for inquiry emails
RESEND_API_KEY=
RESEND_FROM="ShipShelter <onboarding@resend.dev>"
INQUIRY_TO_EMAIL=hello@shipshelter.example.com
